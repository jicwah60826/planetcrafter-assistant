@model List<PlanetCrafterAssistant.Models.Tip>
@using System.Text.Json

@{
    ViewData["Title"] = "Tips & Tricks";
    var jsonOptions = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase };
    var allTipsJson = JsonSerializer.Serialize(Model, jsonOptions);
}

<div class="tips-root">

    <!-- ── VIEW: Tip list ─────────────────────────── -->
    <div class="view-layer" id="tipViewList">
        <div class="tips-page-header">
            <h2 class="tips-page-title">💡 Tips &amp; Tricks</h2>
            <p class="tips-page-subtitle">Community tips to help you thrive on the planet.</p>
        </div>

        <div class="card-grid" id="tipsList">
            @foreach (var tip in Model)
            {
                <div class="item-card"
                     data-id="@tip.Id"
                     onclick="openTip('@tip.Id')">
                    <div class="tips-card-emoji">@tip.Emoji</div>
                    <div class="tips-card-text">
                        <span class="card-label">@tip.Title</span>
                        <span class="tips-card-summary">@tip.Summary</span>
                    </div>
                    <span class="tips-card-category">@tip.Category</span>
                    <span class="pane-row-arrow">›</span>
                </div>
            }
        </div>
    </div>

    <!-- ── VIEW: Tip detail ───────────────────────── -->
    <div class="view-layer view-layer--detail" id="tipViewDetail" aria-label="Tip details">
        <div class="detail-breadcrumb" id="tipBreadcrumb">
            <button class="breadcrumb-item" onclick="closeTip()">← Tips &amp; Tricks</button>
            <span class="breadcrumb-sep">›</span>
            <span class="breadcrumb-item" id="tipBreadcrumbTitle"></span>
        </div>
        <div class="detail-scroll">
            <div class="detail-slot slot-visible" id="tipDetailSlot"></div>
        </div>
    </div>

</div>

@section Scripts {
<script>
    const allTips = @Html.Raw(allTipsJson);

    function openTip(id) {
        var tip = allTips.find(function (t) { return t.id === id; });
        if (!tip) return;

        document.getElementById('tipBreadcrumbTitle').textContent = tip.title;

        document.getElementById('tipDetailSlot').innerHTML =
            '<div class="tip-detail">' +
                '<div class="tip-detail-emoji">' + tip.emoji + '</div>' +
                '<h2 class="pane-title">' + escapeHtml(tip.title) + '</h2>' +
                '<span class="tips-detail-category">' + escapeHtml(tip.category) + '</span>' +
                '<p class="pane-description" style="margin-top:16px;font-style:normal;font-size:14px;color:#d8e8f0">' + escapeHtml(tip.content) + '</p>' +
            '</div>';

        document.getElementById('tipViewList').classList.add('view-exit');
        document.getElementById('tipViewDetail').classList.add('view-enter');
    }

    function closeTip() {
        document.getElementById('tipViewList').classList.remove('view-exit');
        document.getElementById('tipViewDetail').classList.remove('view-enter');
    }

    function escapeHtml(str) {
        var d = document.createElement('div');
        d.appendChild(document.createTextNode(str));
        return d.innerHTML;
    }
</script>
}