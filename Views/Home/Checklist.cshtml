@{
    ViewData["Title"] = "To Do List";
}

<div class="tips-root">
    <div class="view-layer" id="checklistView">
        <div class="tips-page-header">
            <h2 class="tips-page-title">✅ To Do List</h2>
            <p class="tips-page-subtitle">Track your personal goals and tasks.</p>
        </div>

        <div class="checklist-input-row">
            <input type="text"
                   id="todoInput"
                   class="checklist-input"
                   placeholder="Add a new task…"
                   maxlength="200"
                   onkeydown="handleTodoKey(event)"
                   aria-label="New task" />
            <button class="checklist-add-btn" onclick="addTodo()" aria-label="Add task">＋ Add</button>
        </div>

        <ul class="checklist-list" id="todoList" aria-label="Task list"></ul>

        <p class="checklist-empty" id="todoEmpty" style="display:none;">No tasks yet. Add one above!</p>
    </div>
</div>

<style>
    .checklist-input-row {
        display: flex;
        gap: 8px;
        margin: 16px 0;
        padding: 0 4px;
    }

    .checklist-input {
        flex: 1;
        padding: 10px 14px;
        border-radius: 8px;
        border: 1px solid var(--border, #444);
        background: var(--card-bg, #1e1e1e);
        color: var(--text, #eee);
        font-size: 0.95rem;
    }

    .checklist-add-btn {
        padding: 10px 16px;
        border-radius: 8px;
        border: none;
        background: var(--accent, #4caf50);
        color: #fff;
        font-size: 0.95rem;
        cursor: pointer;
        white-space: nowrap;
    }

    .checklist-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .checklist-item {
        display: flex;
        align-items: center;
        gap: 10px;
        background: var(--card-bg, #1e1e1e);
        border: 1px solid var(--border, #444);
        border-radius: 8px;
        padding: 12px 14px;
    }

    .checklist-item input[type="checkbox"] {
        width: 18px;
        height: 18px;
        cursor: pointer;
        flex-shrink: 0;
        accent-color: var(--accent, #4caf50);
    }

    .checklist-item-text {
        flex: 1;
        font-size: 0.95rem;
        color: var(--text, #eee);
        word-break: break-word;
    }

    .checklist-item-text.done {
        text-decoration: line-through;
        opacity: 0.5;
    }

    .checklist-delete-btn {
        background: none;
        border: none;
        color: var(--text-muted, #888);
        font-size: 1.1rem;
        cursor: pointer;
        padding: 2px 6px;
        border-radius: 4px;
        line-height: 1;
    }

    .checklist-delete-btn:hover {
        color: #e55;
    }

    .checklist-empty {
        text-align: center;
        color: var(--text-muted, #888);
        margin-top: 32px;
    }
</style>

<script>
    const STORAGE_KEY = 'pc_checklist';

    function loadTodos() {
        try {
            return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
        } catch {
            return [];
        }
    }

    function saveTodos(todos) {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(todos));
    }

    function renderTodos() {
        var todos = loadTodos();
        var list = document.getElementById('todoList');
        var empty = document.getElementById('todoEmpty');

        list.innerHTML = '';

        if (todos.length === 0) {
            empty.style.display = 'block';
            return;
        }

        empty.style.display = 'none';

        todos.forEach(function (todo) {
            var li = document.createElement('li');
            li.className = 'checklist-item';

            var cb = document.createElement('input');
            cb.type = 'checkbox';
            cb.checked = todo.done;
            cb.setAttribute('aria-label', 'Mark complete');
            cb.onchange = function () { toggleTodo(todo.id); };

            var span = document.createElement('span');
            span.className = 'checklist-item-text' + (todo.done ? ' done' : '');
            span.textContent = todo.text;

            var del = document.createElement('button');
            del.className = 'checklist-delete-btn';
            del.textContent = '🗑';
            del.setAttribute('aria-label', 'Delete task');
            del.onclick = function () { deleteTodo(todo.id); };

            li.appendChild(cb);
            li.appendChild(span);
            li.appendChild(del);
            list.appendChild(li);
        });
    }

    function addTodo() {
        var input = document.getElementById('todoInput');
        var text = input.value.trim();
        if (!text) return;

        var todos = loadTodos();
        todos.push({ id: Date.now().toString(), text: text, done: false });
        saveTodos(todos);

        input.value = '';
        renderTodos();
    }

    function toggleTodo(id) {
        var todos = loadTodos();
        var todo = todos.find(function (t) { return t.id === id; });
        if (todo) todo.done = !todo.done;
        saveTodos(todos);
        renderTodos();
    }

    function deleteTodo(id) {
        var todos = loadTodos().filter(function (t) { return t.id !== id; });
        saveTodos(todos);
        renderTodos();
    }

    function handleTodoKey(event) {
        if (event.key === 'Enter') addTodo();
    }

    renderTodos();
</script>