@{
    ViewData["Title"] = "About & Legal Disclaimer";
}

<div class="about-page">

    <!-- ── Hero banner ──────────────────────────────── -->
    <div class="about-hero">
        <div class="about-hero-icon">🪐</div>
        <div class="about-hero-text">
            <h2 class="about-hero-title">Planet Crafter Assistant</h2>
            <p class="about-hero-sub">Unofficial community reference tool</p>
        </div>
        <span class="about-version-badge">Fan Made</span>
    </div>

    <!-- ── What is this? ────────────────────────────── -->
    <div class="about-card">
        <h3 class="about-card-heading">📖 What is this?</h3>
        <p>
            An unofficial, community-built reference tool to help players browse
            crafting recipes, resources, and game data for <em>The Planet Crafter</em>.
            Quickly look up ingredients, explore item categories, and plan your terraforming path.
        </p>
    </div>

    <!-- ── Legal disclaimer ─────────────────────────── -->
    <div class="about-card about-card--warning">
        <h3 class="about-card-heading">⚖️ Legal Disclaimer</h3>

        <p>
            This website is an unofficial, fan-made companion tool and is <strong>
                not affiliated with,
                endorsed by, or in any way connected to Miju Games
            </strong>.
        </p>

        <p>
            <em>The Planet Crafter™</em> and all related names, items, characters, and assets
            are trademarks and copyrights of <strong>Miju Games</strong>. All in-game icons and
            data are used under Fair Use principles for informational and educational purposes
            to support the player community.
        </p>

        <p>
            If you are a copyright holder and believe your material is being used in a way that
            constitutes copyright infringement, or if you would like specific assets removed,
            please <a href="mailto:contact@planetcrafter-assistant.com" class="about-link">contact me</a>.
        </p>
    </div>

    <!-- ── The game ─────────────────────────────────── -->
    <div class="about-card">
        <h3 class="about-card-heading">🎮 The Game</h3>
        <p>
            <em>The Planet Crafter</em> is a survival open world terraforming game by Miju Games.
            Transform a hostile alien planet into a habitable world for humanity!
        </p>
        <a class="about-steam-btn"
           href="https://store.steampowered.com/app/1284190/The_Planet_Crafter/"
           target="_blank"
           rel="noopener noreferrer">
            <img src="/images/planetCrafterIcon.png" alt="" aria-hidden="true" />
            View on Steam
        </a>
    </div>

</div>