@{
    ViewData["Title"] = "About & Legal Disclaimer";
}

<div class="about-page">
    <section class="about-section">
        <h2 class="about-title">Planet Crafter Assistant</h2>
        <p class="about-lead">
            An unofficial, community-built reference tool to help players browse
            crafting recipes, resources, and game data for <em>The Planet Crafter</em>.
        </p>
    </section>

    <hr class="about-rule" />
    <section class="about-section">
        <h3 class="about-heading">Legal Disclaimer</h3>

        <p>
            This website is an unofficial, fan-made companion tool and is not affiliated with,
            endorsed by, or in any way connected to <strong>Miju Games</strong>.
        </p>

        <p>
            <em>The Planet Crafter™</em> and all related names, items, characters, and assets
            are trademarks and copyrights of <strong>Miju Games</strong>. All in-game icons and
            data are used under Fair Use principles for informational and educational purposes
            to support the player community.
        </p>

        <p>
            If you are a copyright holder and believe your material is being used in a way that
            constitutes copyright infringement, or if you would like specific assets removed,
            please contact <a href="mailto:jon@pixelgraft.com" class="about-link">the site owner</a>.
        </p>
    </section>
</div>

@section Scripts {
<script>
    async function handleFormSubmit(e) {
        e.preventDefault();
        var form = e.target;
        var status = document.getElementById('reportStatus');
        var btn = form.querySelector('button[type="submit"]');

        btn.disabled = true;
        status.textContent = 'Sending\u2026';
        status.className = 'report-status';

        try {
            var response = await fetch(form.action, {
                method: 'POST',
                body: new FormData(form),
                headers: { 'Accept': 'application/json' }
            });

            if (response.ok) {
                status.textContent = '\u2713 Report submitted. Thank you!';
                status.className = 'report-status report-status--ok';
                form.reset();
            } else {
                status.textContent = '\u26a0 Submission failed. Please try again.';
                status.className = 'report-status report-status--err';
                btn.disabled = false;
            }
        } catch {
            status.textContent = '\u26a0 Network error. Please try again.';
            status.className = 'report-status report-status--err';
            btn.disabled = false;
        }
    }
</script>
}