@{
    ViewData["Title"] = "About & Legal Disclaimer";
}

<div class="content about-page">
    <h2 class="about-heading">About Planet Crafter Assistant</h2>
    <p class="about-intro">
        Planet Crafter Assistant is an unofficial, community-built reference tool to help players
        browse crafting recipes, resources, and game data for <em>The Planet Crafter</em>.
    </p>

    <hr class="about-divider" />

    <h3 class="about-subheading">Legal Disclaimer</h3>
    <p>
        This website is an unofficial, fan-made tool and is not affiliated with, endorsed by,
        or in any way connected to <strong>Miju Games</strong>.
    </p>
    <p>
        <em>The Planet Crafter</em> and all related characters, items, names, and assets are the
        sole property and copyright of <strong>Miju Games</strong>. All icons and in-game data
        are used under Fair Use principles for informational and educational purposes to assist
        the player community.
    </p>
    <p>
        This project is non-commercial and free to use. No copyright infringement is intended.
        If you are the copyright holder and wish for any content to be removed, please use the
        form below.
    </p>

    <hr class="about-divider" />

    <h3 class="about-subheading">Database Correction Report</h3>
    <p>Notice a discrepancy in the blueprint data? Submit a correction to the archive.</p>

    <form id="contactForm"
          action="https://formspree.io/f/your-id-here"
          method="POST"
          class="report-form"
          onsubmit="handleFormSubmit(event)">

        <div class="report-form-row">
            <input type="text"
                   id="reportItemName"
                   name="item_name"
                   placeholder="Item Name (e.g. Pulsar Quartz)"
                   required
                   class="report-input" />

            <select name="issue_type" class="report-select">
                <option value="wrong_recipe">Wrong Recipe</option>
                <option value="missing_item">Missing Item</option>
                <option value="wrong_unlock">Unlock Stage Incorrect</option>
                <option value="other">Other / Suggestion</option>
            </select>
        </div>

        <textarea name="message"
                  rows="4"
                  placeholder="Describe the correct recipe or missing data..."
                  required
                  class="report-textarea"></textarea>

        <div class="report-form-footer">
            <button type="submit" class="report-submit">Submit Report</button>
            <span id="reportStatus" class="report-status" aria-live="polite"></span>
        </div>
    </form>
</div>

@section Scripts {
<script>
    async function handleFormSubmit(e) {
        e.preventDefault();
        var form = e.target;
        var status = document.getElementById('reportStatus');
        var btn = form.querySelector('button[type="submit"]');

        btn.disabled = true;
        status.textContent = 'Sending\u2026';
        status.className = 'report-status';

        try {
            var response = await fetch(form.action, {
                method: 'POST',
                body: new FormData(form),
                headers: { 'Accept': 'application/json' }
            });

            if (response.ok) {
                status.textContent = '\u2713 Report submitted. Thank you!';
                status.className = 'report-status report-status--ok';
                form.reset();
            } else {
                status.textContent = '\u26a0 Submission failed. Please try again.';
                status.className = 'report-status report-status--err';
                btn.disabled = false;
            }
        } catch {
            status.textContent = '\u26a0 Network error. Please try again.';
            status.className = 'report-status report-status--err';
            btn.disabled = false;
        }
    }
</script>
}