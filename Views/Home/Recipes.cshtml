@model List<PlanetCrafterAssistant.Models.Recipe>
@using System.Text.Json

@{
    ViewData["Title"] = "Crafting Recipes";
    var jsonOptions = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase };
    var allRecipesJson = JsonSerializer.Serialize(Model, jsonOptions);
    var categories = ViewBag.Categories as List<string> ?? new List<string>();
}

<div class="app-layout">

    <!-- LEFT: Card grid -->
    <div class="panel-left">
        <div class="filter-tabs">
            <button class="tab active" data-filter="all">All Items</button>
            @foreach (var cat in categories)
            {
                <button class="tab" data-filter="@cat">@cat</button>
            }
        </div>

        <div class="card-grid" id="cardGrid">
            @foreach (var recipe in Model)
            {
                <div class="item-card"
                     data-name="@recipe.Name"
                     data-category="@recipe.Category"
                     data-raw="@(recipe.Ingredients.Count == 0 ? "true" : "false")"
                     onclick="selectItem('@recipe.Name')">
                    <div class="card-icon">
                        <img src="/images/icons/@(recipe.IconSlug).png"
                             alt="@recipe.Name"
                             onerror="this.style.display='none';this.nextElementSibling.style.display='block'" />
                        <span class="card-icon-fallback" style="display:none">⚙</span>
                    </div>
                    <div class="card-label">@recipe.Name</div>
                    @if (recipe.Ingredients.Count == 0)
                    {
                        <span class="card-raw-badge">RAW</span>
                    }
                    else
                    {
                        <button class="add-to-cart-btn"
                                data-item="@recipe.Name"
                                title="Add to cart"
                                onclick="event.stopPropagation(); toggleCart('@recipe.Name')">
                            <img src="/images/Cart.png" alt="" aria-hidden="true" style="width:14px;height:14px;object-fit:contain;" />
                        </button>
                    }
                    <span class="card-usedby-badge" style="display:none"></span>
                </div>
            }
        </div>
    </div>

    <!-- RIGHT: Details pane -->
    <div class="panel-right" id="detailsPane">
        <div class="details-placeholder">
            <p>Select an item to view details</p>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const allRecipes = @Html.Raw(allRecipesJson);

    // Navigation history stack
    let navHistory = [];

    function isMobile() { return window.innerWidth <= 600; }

    function closeMobilePane() {
        const pane = document.getElementById('detailsPane');
        pane.classList.remove('mobile-open');
        document.querySelectorAll('.item-card').forEach(c => c.classList.remove('active'));
        navHistory = [];
    }

    function getIconHtml(name) {
        const slug = name.toLowerCase().replace(/ /g, '_');
        return `<img src="/images/icons/${slug}.png"
                     alt="${name}"
                     onerror="this.style.display='none';this.nextElementSibling.style.display='inline'"
                     style="width:48px;height:48px;object-fit:contain" />
                <span style="display:none;font-size:2rem">⚙</span>`;
    }

    const stageIcons = {
        'Heat':     '🌡️',
        'Pressure': '💨',
        'Oxygen':   '🌿',
        'Biomass':  '🧬',
        'Plants':   '🌱',
        'Insects':  '🦋',
        'Animals':  '🐾'
    };

    function getUnlockHtml(unlockCondition) {
        if (!unlockCondition) {
            return `<div class="pane-unlock pane-unlock--always">
                        <span class="pane-unlock-icon">🔓</span>
                        <span>Available from the start</span>
                    </div>`;
        }
        const icon = stageIcons[unlockCondition.stage] || '🔒';
        return `<div class="pane-unlock">
                    <span class="pane-unlock-icon">${icon}</span>
                    <span>
                        Unlocks when <strong>${unlockCondition.stage}</strong>
                        reaches <strong>${unlockCondition.threshold} ${unlockCondition.unit}</strong>
                    </span>
                </div>`;
    }

    function getCraftedInHtml(craftedIn, recyclerYields) {
        if (!craftedIn) return '<div class="pane-list"><div class="pane-empty">Not craftable</div></div>';
        const recyclerRow = recyclerYields
            ? `<div class="pane-row pane-row--recycle">
                   <span class="pane-row-name">♻️ Recycling Machine</span>
                   <span class="pane-row-note">recovers ingredients</span>
               </div>`
            : '';
        return `<div class="pane-list">
                    <div class="pane-row pane-row--station">
                        <span class="pane-row-name">🔧 ${craftedIn}</span>
                    </div>
                    ${recyclerRow}
                </div>`;
    }

    function getBreadcrumbHtml() {
        if (navHistory.length === 0) return '';

        const MAX_VISIBLE = 5;
        let visibleCrumbs = navHistory;
        let collapsedHtml = '';

        if (navHistory.length > MAX_VISIBLE) {
            visibleCrumbs = navHistory.slice(-MAX_VISIBLE);
            const hiddenCount = navHistory.length - MAX_VISIBLE;
            collapsedHtml = `<span class="breadcrumb-collapsed" title="${hiddenCount} earlier steps hidden">…</span>
                             <span class="breadcrumb-sep">›</span>`;
        }

        const startIndex = navHistory.length - visibleCrumbs.length;
        const crumbs = visibleCrumbs.map((name, i) =>
            `<button class="breadcrumb-item"
                     onclick="navigateBack(${startIndex + i})"
                     title="${name}">${name}</button>
             <span class="breadcrumb-sep">›</span>`
        ).join('');

        return `<div class="breadcrumb-trail">${collapsedHtml}${crumbs}</div>`;
    }

    function navigateBack(index) {
        const targetName = navHistory[index];
        navHistory = navHistory.slice(0, index);
        renderItem(targetName);
    }

    function renderItem(name) {
        const recipe = allRecipes.find(r => r.name === name);
        if (!recipe) return;

        document.querySelectorAll('.item-card').forEach(c => c.classList.remove('active'));
        const activeCard = [...document.querySelectorAll('.item-card')]
            .find(c => c.dataset.name === name);
        if (activeCard) {
            activeCard.classList.add('active');
            activeCard.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }

        const usedBy = allRecipes.filter(r =>
            r.ingredients && r.ingredients.some(i => i.name === name)
        );

        const inCart = cart.includes(name);
        const isCraftable = recipe.ingredients && recipe.ingredients.length > 0;
        const cartBtnHtml = isCraftable
            ? `<button class="add-to-cart-btn ${inCart ? 'in-cart' : ''}"
                       style="width:auto;padding:0 12px;height:32px;font-size:13px;margin:0 auto;display:flex;align-items:center;gap:6px"
                       onclick="toggleCart('${name.replace(/'/g, "\\'")}')">
                   <img src="/images/Cart.png" alt="" aria-hidden="true" style="width:14px;height:14px;object-fit:contain;" />
                   ${inCart ? '✓ In Cart' : 'Add to Cart'}
               </button>`
            : '';

        const requiresHtml = recipe.ingredients && recipe.ingredients.length > 0
            ? `<div class="pane-section pane-section--requires">
                 <div class="pane-section-title">REQUIRES (SOURCES)</div>
                 <div class="pane-list">
                   ${recipe.ingredients.map(ing => {
                     const ingSlug     = ing.name.toLowerCase().replace(/ /g, '_');
                     const ingRecipe   = allRecipes.find(r => r.name === ing.name);
                     const isCraftable = ingRecipe && ingRecipe.ingredients && ingRecipe.ingredients.length > 0;
                     const depthBadge  = isCraftable
                         ? `<span class="ing-depth-badge ing-depth-badge--craftable" title="Has its own recipe">⚙</span>`
                         : `<span class="ing-depth-badge ing-depth-badge--raw" title="Raw material">◆</span>`;
                     return `<div class="pane-row clickable" onclick="selectItem('${ing.name}')">
                        <span class="pane-row-name">
                          <img src="/images/icons/${ingSlug}.png"
                               alt="${ing.name}"
                               class="pane-row-icon"
                               onerror="this.style.display='none'" />
                          ${ing.name}
                        </span>
                        <span class="pane-row-right">
                          ${depthBadge}
                          <span class="pane-row-qty">x${ing.quantity}</span>
                        </span>
                      </div>`;
                   }).join('')}
                 </div>
               </div>`
            : `<div class="pane-section pane-section--requires">
                 <div class="pane-section-title">REQUIRES (SOURCES)</div>
                 <div class="pane-list"><div class="pane-empty">No ingredients — raw material</div></div>
               </div>`;

        const usedByHtml = usedBy.length > 0
            ? `<div class="pane-section pane-section--usedby">
                 <div class="pane-section-title">USED BY (DERIVED)</div>
                 <div class="pane-list">
                   ${usedBy.map(r => {
                     const slug = r.name.toLowerCase().replace(/ /g, '_');
                     return `<div class="pane-row clickable" onclick="selectItem('${r.name}')">
                        <span class="pane-row-name">
                          <img src="/images/icons/${slug}.png"
                               alt="${r.name}"
                               class="pane-row-icon"
                               onerror="this.style.display='none'" />
                          ${r.name}
                        </span>
                        <span class="pane-row-arrow">→</span>
                      </div>`;
                   }).join('')}
                 </div>
               </div>`
            : '';

        const backBtnHtml = `<button class="pane-back-btn" onclick="closeMobilePane()">← Back</button>`;

        const pane = document.getElementById('detailsPane');
        pane.innerHTML = `
            ${backBtnHtml}
            ${getBreadcrumbHtml()}
            <div class="pane-icon">${getIconHtml(recipe.name)}</div>
            <h2 class="pane-title">${recipe.name}</h2>
            ${cartBtnHtml}
            <p class="pane-description" style="margin-top:10px">${recipe.description || ''}</p>
            <div class="pane-section">
                <div class="pane-section-title">UNLOCKS</div>
                ${getUnlockHtml(recipe.unlockCondition)}
            </div>
            <div class="pane-section pane-section--crafted">
                <div class="pane-section-title">CRAFTED IN</div>
                ${getCraftedInHtml(recipe.craftedIn, recipe.recyclerYields)}
            </div>
            ${requiresHtml}
            ${usedByHtml}
        `;

        if (isMobile()) pane.classList.add('mobile-open');
    }

    // Toggle cart membership from any button
    function toggleCart(name) {
        if (cart.includes(name)) {
            removeFromCart(name);
        } else {
            addToCart(name);
        }
        // Re-render the detail pane so the in-pane button label updates too
        const currentTitle = document.querySelector('#detailsPane .pane-title');
        if (currentTitle && currentTitle.textContent.trim() === name) {
            renderItem(name);
        }
    }

    // Public entry point — pushes current item to history before navigating
    function selectItem(name) {
        const currentTitle = document.querySelector('#detailsPane .pane-title');
        if (currentTitle && currentTitle.textContent) {
            navHistory.push(currentTitle.textContent.trim());
        }
        renderItem(name);
    }

    // --- USED BY count badges ---
    (function buildUsedByBadges() {
        const usedByCount = {};
        allRecipes.forEach(r => {
            if (!r.ingredients) return;
            r.ingredients.forEach(ing => {
                usedByCount[ing.name] = (usedByCount[ing.name] || 0) + 1;
            });
        });
        document.querySelectorAll('.item-card').forEach(card => {
            const count = usedByCount[card.dataset.name] || 0;
            if (count > 0) {
                const badge = card.querySelector('.card-usedby-badge');
                if (badge) {
                    badge.textContent = `${count} recipe${count === 1 ? '' : 's'}`;
                    badge.style.display = 'inline-block';
                }
            }
        });
    })();

    // Sync cart button states on page load
    syncCartButtons();

    // --- Filter tabs ---
    document.querySelectorAll('.tab').forEach(tab => {
        tab.addEventListener('click', () => {
            document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
            tab.classList.add('active');
            applyFilters();
        });
    });
</script>
}