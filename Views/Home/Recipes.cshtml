@model List<PlanetCrafterAssistant.Models.Recipe>
@using System.Text.Json

@{
    ViewData["Title"] = "Crafting Recipes";
    var jsonOptions = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase };
    var allRecipesJson = JsonSerializer.Serialize(Model, jsonOptions);
}

<div class="recipes-root">

    <!-- ── VIEW: Item list ─────────────────────────── -->
    <div class="view-layer" id="viewList">

        <div class="card-grid" id="cardGrid">
            @foreach (var recipe in Model)
            {
                <div class="item-card"
                     data-name="@recipe.Name"
                     data-category="@recipe.Category"
                     data-raw="@(recipe.Ingredients.Count == 0 ? "true" : "false")"
                     onclick="selectItem('@recipe.Name.Replace("'", "\\'")')">
                    <div class="card-icon">
                        <img src="/images/icons/@(recipe.IconSlug).png"
                             alt="@recipe.Name"
                             onerror="this.style.display='none';this.nextElementSibling.style.display='block'" />
                        <span class="card-icon-fallback" style="display:none">⚙</span>
                    </div>
                    <div class="card-label">@recipe.Name</div>
                    @if (recipe.Ingredients.Count == 0)
                    {
                        <span class="card-raw-badge">RAW</span>
                    }
                    else
                    {
                        <button class="add-to-cart-btn"
                                data-item="@recipe.Name"
                                title="Add to cart"
                                onclick="event.stopPropagation(); toggleCart('@recipe.Name.Replace("'", "\\'")')">
                            <img src="/images/Cart.png" alt="" aria-hidden="true" style="width:14px;height:14px;object-fit:contain;" />
                        </button>
                    }
                    <span class="card-usedby-badge" style="display:none"></span>
                </div>
            }
        </div>
    </div>

    <!-- ── VIEW: Item detail ───────────────────────── -->
    <div class="view-layer view-layer--detail" id="viewDetail" aria-label="Item details">
        <!-- Sticky breadcrumb -->
        <div class="detail-breadcrumb" id="detailBreadcrumb"></div>
        <!-- Scroll container that holds the animating content slots -->
        <div class="detail-scroll" id="detailScroll">
            <div class="detail-slot" id="detailSlotA"></div>
            <div class="detail-slot" id="detailSlotB"></div>
        </div>
    </div>

</div>

@section Scripts {
<script>
    const allRecipes = @Html.Raw(allRecipesJson);

    // ── Navigation state ─────────────────────────────────────
    let navStack   = [];
    let detailOpen = false;
    let activeSlot = 'A';

    // ── Helpers ──────────────────────────────────────────────
    function getSlot(id)   { return document.getElementById('detailSlot' + id); }
    function otherSlot(id) { return id === 'A' ? 'B' : 'A'; }

    function getIconHtml(name) {
        const slug = name.toLowerCase().replace(/ /g, '_');
        return `<img src="/images/icons/${slug}.png"
                     alt="${name}"
                     onerror="this.style.display='none';this.nextElementSibling.style.display='inline'"
                     style="width:60px;height:60px;object-fit:contain" />
                <span style="display:none;font-size:2.5rem">⚙</span>`;
    }

    const stageIcons = {
        'Heat':     '🌡️',
        'Pressure': '💨',
        'Oxygen':   '🌿',
        'Biomass':  '🧬',
        'Plants':   '🌱',
        'Insects':  '🦋',
        'Animals':  '🐾'
    };

    function getUnlockIconHtml(imgFile, fallbackEmoji) {
        return `<img src="/images/${imgFile}"
                     alt="${fallbackEmoji}"
                     onerror="this.style.display='none';this.nextElementSibling.style.display='inline'"
                     class="pane-unlock-icon-img" />
                <span style="display:none">${fallbackEmoji}</span>`;
    }

    function getUnlockHtml(uc) {
        if (!uc || uc.type === 'always') {
            return `<div class="pane-unlock pane-unlock--always">
                        <span class="pane-unlock-icon">🔓</span>
                        <span>Available from the start</span>
                    </div>`;
        }
        const typeMap = {
            terraformation: () => {
                const icon = stageIcons[uc.stage] || '🌍';
                return `<div class="pane-unlock pane-unlock--terra">
                            <span class="pane-unlock-icon">${icon}</span>
                            <span>Unlocks when <strong>${uc.stage}</strong>
                            reaches <strong>${uc.threshold} ${uc.unit}</strong></span>
                        </div>`;
            },
            blueprint: () =>
                `<div class="pane-unlock pane-unlock--blueprint">
                     <span class="pane-unlock-icon">${getUnlockIconHtml('blueprint_t_t1.png', '📋')}</span>
                     <span>Found via <strong>Blueprint Chip</strong>
                     ${uc.blueprintSource ? `<br><span class="pane-unlock-sub">${uc.blueprintSource}</span>` : ''}
                     </span>
                 </div>`,
            trade: () =>
                `<div class="pane-unlock pane-unlock--trade">
                     <span class="pane-unlock-icon">${getUnlockIconHtml('tradePlatform.png', '🏪')}</span>
                     <span>Purchased from the <strong>Trade Platform</strong>
                     ${uc.tradeCost ? `<br><span class="pane-unlock-sub">Cost: ${uc.tradeCost}</span>` : ''}
                     </span>
                 </div>`,
            story: () =>
                `<div class="pane-unlock pane-unlock--story">
                     <span class="pane-unlock-icon">📖</span>
                     <span>Unlocked via <strong>Story Progression</strong>
                     ${uc.storyEvent ? `<br><span class="pane-unlock-sub">${uc.storyEvent}</span>` : ''}
                     </span>
                 </div>`,
        };
        const renderer = typeMap[uc.type];
        return renderer
            ? renderer()
            : `<div class="pane-unlock"><span class="pane-unlock-icon">🔒</span><span>${uc.type}</span></div>`;
    }

    function getCraftedInHtml(craftedIn, recyclerYields) {
        if (!craftedIn) return '<div class="pane-list"><div class="pane-empty">Not craftable</div></div>';
        const recyclerRow = recyclerYields
            ? `<div class="pane-row pane-row--recycle">
                   <span class="pane-row-name">♻️ Recycling Machine</span>
                   <span class="pane-row-note">recovers ingredients</span>
               </div>`
            : '';
        return `<div class="pane-list">
                    <div class="pane-row pane-row--station">
                        <span class="pane-row-name">🔧 ${craftedIn}</span>
                    </div>
                    ${recyclerRow}
                </div>`;
    }

    function buildDetailHtml(recipe) {
        const usedBy      = allRecipes.filter(r => r.ingredients && r.ingredients.some(i => i.name === recipe.name));
        const inCart      = isInCart(recipe.name);
        const isCraftable = recipe.ingredients && recipe.ingredients.length > 0;

        const cartBtnHtml = isCraftable
            ? `<button class="add-to-cart-btn detail-cart-btn ${inCart ? 'in-cart' : ''}"
                       data-item="${recipe.name}"
                       onclick="toggleCart('${recipe.name.replace(/'/g, "\\'")}')">
                   <img src="/images/Cart.png" alt="" aria-hidden="true" style="width:14px;height:14px;object-fit:contain;" />
                   ${inCart ? '✓ In Cart' : 'Add to Cart'}
               </button>`
            : '';

        const requiresHtml = isCraftable
            ? `<div class="pane-section pane-section--requires">
                 <div class="pane-section-title">REQUIRES (SOURCES)</div>
                 <div class="pane-list">
                   ${recipe.ingredients.map(ing => {
                     const ingSlug   = ing.name.toLowerCase().replace(/ /g, '_');
                     const ingRecipe = allRecipes.find(r => r.name === ing.name);
                     const craftable = ingRecipe && ingRecipe.ingredients && ingRecipe.ingredients.length > 0;
                     const badge     = craftable
                         ? `<span class="ing-depth-badge ing-depth-badge--craftable" title="Has its own recipe">⚙</span>`
                         : `<span class="ing-depth-badge ing-depth-badge--raw" title="Raw material">◆</span>`;
                     return `<div class="pane-row clickable" onclick="selectItem('${ing.name.replace(/'/g, "\\'")}')">
                               <span class="pane-row-name">
                                 <img src="/images/icons/${ingSlug}.png" alt="${ing.name}"
                                      class="pane-row-icon" onerror="this.style.display='none'" />
                                 ${ing.name}
                               </span>
                               <span class="pane-row-right">${badge}<span class="pane-row-qty">x${ing.quantity}</span></span>
                             </div>`;
                   }).join('')}
                 </div>
               </div>`
            : `<div class="pane-section pane-section--requires">
                 <div class="pane-section-title">REQUIRES (SOURCES)</div>
                 <div class="pane-list"><div class="pane-empty">No ingredients — raw material</div></div>
               </div>`;

        const usedByHtml = usedBy.length > 0
            ? `<div class="pane-section pane-section--usedby">
                 <div class="pane-section-title">USED BY (DERIVED)</div>
                 <div class="pane-list">
                   ${usedBy.map(r => {
                     const slug = r.name.toLowerCase().replace(/ /g, '_');
                     return `<div class="pane-row clickable" onclick="selectItem('${r.name.replace(/'/g, "\\'")}')">
                               <span class="pane-row-name">
                                 <img src="/images/icons/${slug}.png" alt="${r.name}"
                                      class="pane-row-icon" onerror="this.style.display='none'" />
                                 ${r.name}
                               </span>
                               <span class="pane-row-arrow">→</span>
                             </div>`;
                   }).join('')}
                 </div>
               </div>`
            : '';

        return `
            <div class="detail-hero">
                <div class="pane-icon">${getIconHtml(recipe.name)}</div>
                <h2 class="pane-title">${recipe.name}</h2>
                ${cartBtnHtml}
                <p class="pane-description">${recipe.description || ''}</p>
            </div>
            <div class="pane-section">
                <div class="pane-section-title">UNLOCKS</div>
                ${getUnlockHtml(recipe.unlockCondition)}
            </div>
            <div class="pane-section pane-section--crafted">
                <div class="pane-section-title">CRAFTED IN</div>
                ${getCraftedInHtml(recipe.craftedIn, recipe.recyclerYields)}
            </div>
            ${requiresHtml}
            ${usedByHtml}
        `;
    }

    // ── Breadcrumb ───────────────────────────────────────────
    // currentItem: the name being rendered RIGHT NOW (not yet on navStack)
    function renderBreadcrumb(currentItem) {
        const el = document.getElementById('detailBreadcrumb');
        if (!el) return;

        // Full trail: root + history + the item currently on screen
        const allCrumbs = ['All Items', ...navStack, currentItem];
        const MAX_VISIBLE = 5;
        let visible = allCrumbs;
        let collapsedHtml = '';

        if (allCrumbs.length > MAX_VISIBLE) {
            visible = allCrumbs.slice(-MAX_VISIBLE);
            const hiddenCount = allCrumbs.length - MAX_VISIBLE;
            collapsedHtml = `<span class="breadcrumb-collapsed" title="${hiddenCount} earlier steps hidden">…</span>
                             <span class="breadcrumb-sep">›</span>`;
        }

        const startIndex = allCrumbs.length - visible.length;
        const crumbs = visible.map((label, i) => {
            const absIndex = startIndex + i;

            // Last crumb = current item, always non-clickable
            if (absIndex === allCrumbs.length - 1) {
                return `<span class="breadcrumb-current">${label}</span>`;
            }
            // "All Items" root — always a clickable button
            if (absIndex === 0) {
                return `<button class="breadcrumb-item" onclick="closeDetail()" title="Back to item list">${label}</button>
                        <span class="breadcrumb-sep">›</span>`;
            }
            // Mid-stack item
            return `<button class="breadcrumb-item"
                             onclick="navigateBack(${absIndex})"
                             title="${label}">${label}</button>
                     <span class="breadcrumb-sep">›</span>`;
        }).join('');

        el.innerHTML = `${collapsedHtml}${crumbs}`;
    }

    // ── Slot animation ───────────────────────────────────────
    function animateToSlot(html, direction) {
        const incoming = otherSlot(activeSlot);
        const inEl     = getSlot(incoming);
        const outEl    = getSlot(activeSlot);

        // Populate and reset the incoming slot
        inEl.innerHTML = html;
        inEl.scrollTop = 0;
        inEl.classList.remove('slot-enter-left', 'slot-enter-right',
                               'slot-exit-left',  'slot-exit-right',
                               'slot-visible',     'slot-animating');
        outEl.classList.remove('slot-enter-left', 'slot-enter-right',
                                'slot-exit-left',  'slot-exit-right',
                                'slot-animating');

        // Stage incoming off-screen in the correct direction
        inEl.classList.add(direction === 'forward' ? 'slot-enter-right' : 'slot-enter-left');

        // Force reflow so the browser paints the start position before transitioning
        inEl.getBoundingClientRect();

        // Enable transitions on both slots, then move them
        inEl.classList.add('slot-animating');
        outEl.classList.add('slot-animating');

        if (direction === 'forward') {
            inEl.classList.replace('slot-enter-right', 'slot-visible');
            outEl.classList.add('slot-exit-left');
        } else {
            inEl.classList.replace('slot-enter-left', 'slot-visible');
            outEl.classList.add('slot-exit-right');
        }

        // Clean up after the transition completes
        setTimeout(() => {
            outEl.classList.remove('slot-visible', 'slot-exit-left', 'slot-exit-right', 'slot-animating');
            outEl.innerHTML = '';
            inEl.classList.remove('slot-animating');
            activeSlot = incoming;
        }, 320);
    }

    // ── View-level open / close (list ↔ detail layer) ────────
    function openDetail(html, direction) {
        if (!detailOpen) {
            // ── First open ──────────────────────────────────
            const slotA = getSlot('A');
            slotA.innerHTML = html;
            slotA.scrollTop = 0;
            slotA.classList.add('slot-visible');
            activeSlot = 'A';
            detailOpen = true;

            document.body.classList.add('detail-active');           // ← hide search
            document.getElementById('viewList').classList.add('view-exit');
            document.getElementById('viewDetail').classList.add('view-enter');
        } else {
            // ── Subsequent navigations ───────────────────────
            animateToSlot(html, direction);
        }
    }

    function closeDetail() {
        if (!detailOpen) return;
        detailOpen = false;
        navStack   = [];

        document.body.classList.remove('detail-active');            // ← restore search
        document.getElementById('viewList').classList.remove('view-exit');
        document.getElementById('viewDetail').classList.remove('view-enter');

        setTimeout(() => {
            getSlot('A').innerHTML = '';
            getSlot('B').innerHTML = '';
            getSlot('A').className = 'detail-slot';
            getSlot('B').className = 'detail-slot';
            activeSlot = 'A';
        }, 320);

        document.querySelectorAll('.item-card').forEach(c => c.classList.remove('active', 'was-active'));
        const wasActive = document.querySelector('.item-card.was-active');
        if (wasActive) wasActive.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    // ── Core render ──────────────────────────────────────────
    function renderItem(name, direction) {
        const recipe = allRecipes.find(r => r.name === name) ?? {
            name:            name,
            category:        '',
            description:     '',
            ingredients:     [],
            unlockCondition: { type: 'always' },
            craftedIn:       null,
            recyclerYields:  false
        };

        const html = buildDetailHtml(recipe);
        renderBreadcrumb(name);
        openDetail(html, direction || 'forward');
    }

    // ── Navigate back via breadcrumb ─────────────────────────
    function navigateBack(absIndex) {
        const targetName = navStack[absIndex - 1];
        navStack = navStack.slice(0, absIndex - 1);
        renderItem(targetName, 'backward');
    }

    // ── Cart toggle ──────────────────────────────────────────
    function toggleCart(name) {
        if (isInCart(name)) {
            removeFromCart(name);
        } else {
            addToCart(name);
        }
        const btn = document.querySelector(`.detail-cart-btn[data-item="${CSS.escape(name)}"]`);
        if (btn) {
            const inCart = isInCart(name);
            btn.className = `add-to-cart-btn detail-cart-btn${inCart ? ' in-cart' : ''}`;
            btn.innerHTML = `<img src="/images/Cart.png" alt="" aria-hidden="true" style="width:14px;height:14px;object-fit:contain;" />
                             ${inCart ? '✓ In Cart' : 'Add to Cart'}`;
        }
    }

    // ── Public entry point ───────────────────────────────────
    function selectItem(name) {
        if (detailOpen) {
            const currentTitle = getSlot(activeSlot).querySelector('.pane-title');
            if (currentTitle) navStack.push(currentTitle.textContent.trim());
        }

        document.querySelectorAll('.item-card').forEach(c => c.classList.remove('active', 'was-active'));
        const card = [...document.querySelectorAll('.item-card')].find(c => c.dataset.name === name);
        if (card) card.classList.add('active', 'was-active');

        renderItem(name, 'forward');
    }

    // ── USED BY count badges ─────────────────────────────────
    (function buildUsedByBadges() {
        const counts = {};
        allRecipes.forEach(r => {
            (r.ingredients || []).forEach(ing => {
                counts[ing.name] = (counts[ing.name] || 0) + 1;
            });
        });
        document.querySelectorAll('.item-card').forEach(card => {
            const n = counts[card.dataset.name] || 0;
            if (n > 0) {
                const badge = card.querySelector('.card-usedby-badge');
                if (badge) {
                    badge.textContent = `${n} recipe${n === 1 ? '' : 's'}`;
                    badge.style.display = 'inline-block';
                }
            }
        });
    })();

    syncCartButtons();

    // ── Auto-select item from URL hash (e.g. navigated from cart) ────
    (function () {
        var hash = window.location.hash;
        if (hash && hash.startsWith('#item=')) {
            var name = decodeURIComponent(hash.slice(6));
            history.replaceState(null, '', window.location.pathname);
            if (name) {
                selectItem(name);
            }
        }
    })();
</script>
}