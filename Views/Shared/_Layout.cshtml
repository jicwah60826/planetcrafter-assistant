<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Planet Crafter Assistant</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PlanetCrafterAssistant.styles.css" asp-append-version="true" />
</head>
<body>

    <!-- Top Bar -->
    <header class="top-bar">
        <h1>Planet Crafter Assistant</h1>
        <div class="search-wrapper">
            <input type="text" id="searchBox" placeholder="Search items or categories..."
                   class="search-box" oninput="filterCards()" />
            <button id="searchClear" class="search-clear" onclick="clearSearch()" title="Clear search">✕</button>
        </div>
    </header>

    <!-- Main Content -->
    <main>
        @RenderBody()
    </main>

    <!-- Bottom Navigation -->
    <nav class="bottom-nav">
        <a href="/">Home</a>
        <a href="/Home/Recipes">Crafting</a>
    </nav>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        document.querySelectorAll('.bottom-nav a').forEach(link => {
            if (link.href === window.location.href) {
                link.classList.add('active');
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
