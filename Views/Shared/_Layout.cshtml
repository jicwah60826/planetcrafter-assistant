<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Planet Crafter Assistant</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PlanetCrafterAssistant.styles.css" asp-append-version="true" />

    <!-- PWA / iOS home screen support -->
    <link rel="manifest" href="~/manifest.json" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="PC Assistant" />
    <link rel="apple-touch-icon" href="~/images/icons/apple-touch-icon.png" />
</head>
<body data-show-home="@(ViewData["ShowHomeIcon"] != null ? "true" : "false")">

    <!-- Flyout overlay backdrop -->
    <div class="flyout-backdrop" id="flyoutBackdrop" onclick="closeFlyout()"></div>

    <!-- Flyout menu (slides in from left) -->
    <nav class="flyout-menu" id="flyoutMenu" aria-label="Site navigation">
        <div class="flyout-header">
            <span class="flyout-title">Menu</span>
            <button class="flyout-close" onclick="closeFlyout()" aria-label="Close menu">✕</button>
        </div>
        <ul class="flyout-links">
            <li><a href="/"><img src="~/images/Home.png" alt="" class="nav-home-icon" aria-hidden="true" /> Home</a></li>
            <li><a href="/Home/TipsAndTricks">💡 Tips &amp; Tricks</a></li>
            <li><a href="/Home/About">ℹ️ About</a></li>
            <li class="flyout-links-divider"></li>
            <li>
                <a href="https://store.steampowered.com/app/1284190/The_Planet_Crafter/"
                   target="_blank" rel="noopener noreferrer"
                   class="flyout-steam-link">
                    <img src="~/images/planetCrafterIcon.png"
                         alt="" class="nav-game-icon" aria-hidden="true" />
                    Get The Planet Crafter on Steam
                </a>
            </li>
        </ul>
    </nav>

    <!-- Cart backdrop -->
    <div class="cart-backdrop" id="cartBackdrop" onclick="closeCart()"></div>

    <!-- Cart panel (slides in from right) -->
    <div class="cart-panel" id="cartPanel">
        <div class="cart-panel-header">
            <span class="cart-panel-title">
                <img src="~/images/Cart.png" alt="" class="nav-cart-icon" aria-hidden="true" />
                Crafting Cart
            </span>
            <button class="cart-panel-close" onclick="closeCart()" aria-label="Close cart">✕</button>
        </div>
        <div class="cart-panel-body" id="cartPanelBody">
            <p class="cart-empty-msg">
                Your cart is empty.<br />
                Add craftable items using the <img src="~/images/Cart.png" alt="cart" style="width:13px;height:13px;object-fit:contain;vertical-align:middle;" /> button.
            </p>
        </div>
    </div>

    <!-- Top Bar -->
    <header class="top-bar">
        <div class="top-bar-inner">
            <button class="hamburger-btn" id="hamburgerBtn" onclick="openFlyout()" aria-label="Open menu">
                <span></span>
                <span></span>
                <span></span>
            </button>

            <h1>Planet Crafter Assistant</h1>

            <div class="top-bar-right">
                <a href="https://store.steampowered.com/app/1284190/The_Planet_Crafter/"
                   target="_blank" rel="noopener noreferrer"
                   class="top-bar-steam-btn" title="Get The Planet Crafter on Steam">
                    <img src="~/images/planetCrafterIcon.png"
                         alt="" class="nav-game-icon" aria-hidden="true" />
                    Steam
                </a>
                <div class="search-wrapper">
                    <input type="text" id="searchBox" placeholder="Search items..."
                           class="search-box" oninput="filterCards()" />
                    <button id="searchClear" class="search-clear" onclick="clearSearch()" title="Clear search">✕</button>
                </div>
                <a href="/" class="top-bar-home-btn" id="homeIconBtn" aria-label="Back to home" title="Home">
                    <img src="~/images/Home.png" alt="" class="nav-home-icon" aria-hidden="true" />
                </a>
                <button class="cart-btn" id="cartToggleBtn" onclick="openCart()" title="View crafting cart" aria-label="Crafting cart">
                    <img src="~/images/Cart.png" alt="" class="nav-cart-icon" aria-hidden="true" />
                    <span class="cart-badge" id="cartBadge">0</span>
                </button>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main>
        @RenderBody()
    </main>

    <!-- Bottom Navigation (fixed) -->
    <nav class="bottom-nav">
        <div class="bottom-nav-footer">
            <span>Planet Crafter Assistant &mdash; Unofficial fan tool</span>
            <a href="/Home/About">Legal Disclaimer</a>
            <span class="build-id">build: @Context.Items["BuildId"]</span>
        </div>
    </nav>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        // Home icon visibility
        (function () {
            var showHome = document.body.dataset.showHome === 'true';
            var btn = document.getElementById('homeIconBtn');
            if (btn) btn.style.display = showHome ? 'flex' : 'none';
        })();

        // Flyout menu
        function openFlyout() {
            document.getElementById('flyoutMenu').classList.add('open');
            document.getElementById('flyoutBackdrop').classList.add('open');
            document.body.classList.add('flyout-active');
        }

        function closeFlyout() {
            document.getElementById('flyoutMenu').classList.remove('open');
            document.getElementById('flyoutBackdrop').classList.remove('open');
            document.body.classList.remove('flyout-active');
        }

        // ── Cart (localStorage-backed) ─────────────────────────
        var cart = JSON.parse(localStorage.getItem('pc-cart') || '[]');

        if (cart.length > 0 && typeof cart[0] === 'string') {
            cart = cart.map(function (n) { return { name: n, qty: 1 }; });
        }

        function saveCart() { localStorage.setItem('pc-cart', JSON.stringify(cart)); }

        function cartEntry(name) { return cart.find(function (e) { return e.name === name; }); }

        function isInCart(name) { return !!cartEntry(name); }

        function openCart() {
            renderCartPanel();
            document.getElementById('cartPanel').classList.add('open');
            document.getElementById('cartBackdrop').classList.add('open');
        }

        function closeCart() {
            document.getElementById('cartPanel').classList.remove('open');
            document.getElementById('cartBackdrop').classList.remove('open');
        }

        function addToCart(name) {
            var entry = cartEntry(name);
            if (entry) { entry.qty += 1; } else { cart.push({ name: name, qty: 1 }); }
            saveCart(); updateCartBadge(); syncCartButtons(); renderCartPanel();
        }

        function removeFromCart(name) {
            cart = cart.filter(function (e) { return e.name !== name; });
            saveCart(); updateCartBadge(); syncCartButtons(); renderCartPanel();
        }

        function setCartQty(name, qty) {
            var n = parseInt(qty, 10);
            if (isNaN(n) || n < 1) { removeFromCart(name); return; }
            var entry = cartEntry(name);
            if (entry) { entry.qty = n; saveCart(); renderCartPanel(); }
        }

        function clearCart() {
            cart = [];
            saveCart(); updateCartBadge(); syncCartButtons(); renderCartPanel();
        }

        function updateCartBadge() {
            var total = cart.reduce(function (sum, e) { return sum + e.qty; }, 0);
            var badge = document.getElementById('cartBadge');
            if (badge) { badge.textContent = total; badge.style.display = total > 0 ? 'block' : 'none'; }
        }

        function syncCartButtons() {
            document.querySelectorAll('.add-to-cart-btn[data-item]').forEach(function (btn) {
                btn.classList.toggle('in-cart', isInCart(btn.dataset.item));
            });
        }

        function renderCartPanel() {
            var body = document.getElementById('cartPanelBody');
            if (!body) return;
            if (cart.length === 0) {
                body.innerHTML = '<p class="cart-empty-msg">Your cart is empty.<br />Add craftable items using the <img src="/images/Cart.png" alt="cart" style="width:13px;height:13px;object-fit:contain;vertical-align:middle;" /> button.</p>';
                return;
            }
            var itemsHtml = cart.map(function (e) {
                var slug = e.name.toLowerCase().replace(/ /g, '_');
                var safeName = e.name.replace(/'/g, "\\'");
                return '<div class="cart-item-row">' +
                    '<img class="cart-item-icon" src="/images/icons/' + slug + '.png" alt="" onerror="this.style.display=\'none\'" />' +
                    '<span class="cart-item-name">' + e.name + '</span>' +
                    '<div class="cart-qty-controls">' +
                    '<button class="cart-qty-btn" onclick="setCartQty(\'' + safeName + '\', ' + (e.qty - 1) + ')">−</button>' +
                    '<span class="cart-qty-value">' + e.qty + '</span>' +
                    '<button class="cart-qty-btn" onclick="setCartQty(\'' + safeName + '\', ' + (e.qty + 1) + ')">+</button>' +
                    '</div>' +
                    '<button class="cart-item-remove" onclick="removeFromCart(\'' + safeName + '\')" title="Remove">✕</button>' +
                    '</div>';
            }).join('');
            var gatherMap = {};
            cart.forEach(function (e) {
                var recipe = (typeof allRecipes !== 'undefined')
                    ? allRecipes.find(function (r) { return r.name === e.name; }) : null;
                if (recipe && recipe.ingredients && recipe.ingredients.length > 0) {
                    recipe.ingredients.forEach(function (ing) {
                        gatherMap[ing.name] = (gatherMap[ing.name] || 0) + (ing.quantity * e.qty);
                    });
                }
            });
            var gatherEntries = Object.keys(gatherMap);
            var gatherHtml = '';
            if (gatherEntries.length > 0) {
                gatherHtml = '<div class="cart-section"><div class="cart-section-title cart-section-title--gather">Materials to Gather</div>' +
                    gatherEntries.map(function (n) {
                        var slug = n.toLowerCase().replace(/ /g, '_');
                        return '<div class="gather-row"><img class="gather-row-icon" src="/images/icons/' + slug + '.png" alt="" onerror="this.style.display=\'none\'" />' +
                            '<span class="gather-row-name">' + n + '</span><span class="gather-row-qty">x' + gatherMap[n] + '</span></div>';
                    }).join('') + '</div>';
            }
            body.innerHTML =
                '<div class="cart-section"><div class="cart-section-title">Items to Craft</div>' + itemsHtml + '</div>' +
                gatherHtml +
                '<button class="cart-clear-btn" onclick="clearCart()">✕ Clear Cart</button>';
        }

        updateCartBadge();
        syncCartButtons();
    </script>
    @await RenderSectionAsync("Scripts", required: false)

    <!-- PWA service worker registration -->
    <script>
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/sw.js');
        }
    </script>
</body>
</html>
